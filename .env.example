# ─────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# GitHub API Token (required for repo analysis, raises rate limit 60→5000 req/hr)
# Get from: https://github.com/settings/tokens → Generate new token (classic) → public_repo scope
GITHUB_TOKEN=ghp_your_token_here

# Groq API Key (optional, enables advanced TTS)
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# CORS - comma-separated list of allowed frontend origins
# For Railway+Vercel: update with your actual deployed URLs
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# Server config (Railway sets PORT automatically, these are fallbacks)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
