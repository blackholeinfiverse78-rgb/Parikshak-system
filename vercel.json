{
  "version": 2,
  "name": "task-review-agent-frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm ci",
  "framework": "create-react-app",
  "env": {
    "REACT_APP_API_BASE": "https://task-review-backend.onrender.com/api/v1"
  },
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}